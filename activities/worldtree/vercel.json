{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors https://discord.com https://*.discord.com;"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://discord.com"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/.proxy/api/:path*",
      "destination": "https://dbg-worldtree-api.vercel.app/api/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://dbg-worldtree-api.vercel.app/api/:path*"
    }
  ]
}
